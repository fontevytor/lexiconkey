rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/studentAccounts/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "fontevytor@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(username) {
      return isAuthenticated() && (request.auth.uid == username || request.auth.token.name == username);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /studentAccounts/{username} {
      allow read: if true; // Needed for login check
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userProgress/{username}/{document=**} {
      allow read: if isAdmin() || isOwner(username);
      allow write: if isAdmin() || isOwner(username);
    }

    match /userNotes/{username}/{document=**} {
      allow read: if isAdmin() || isOwner(username);
      allow write: if isAdmin() || isOwner(username);
    }

    match /userStats/{username}/{document=**} {
      allow read: if isAdmin() || isOwner(username);
      allow write: if isAdmin() || isOwner(username);
    }

    match /studentActivity/{username} {
      allow read: if isAdmin() || isOwner(username);
      allow write: if isAdmin() || isOwner(username);
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
