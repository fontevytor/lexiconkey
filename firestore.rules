rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "fontevytor@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(username) {
      return isAuthenticated() && (
        request.auth.uid == username || 
        (exists(/databases/$(database)/documents/studentAccounts/$(username)) && 
         get(/databases/$(database)/documents/studentAccounts/$(username)).data.uid == request.auth.uid)
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /studentAccounts {
      allow read: if true;
      allow write: if isAdmin();
      match /{username} {
        allow read: if true; 
        allow create: if isAdmin();
        allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid']));
        allow delete: if isAdmin();
      }
    }

    match /lessons {
      allow read: if true;
      allow write: if isAdmin();
      match /{lessonId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /userProgress {
      allow read: if isAdmin();
      match /{username}/{document=**} {
        allow read: if isAdmin() || isOwner(username);
        allow write: if isAdmin() || isOwner(username);
      }
    }

    match /userNotes {
      allow read: if isAdmin();
      match /{username}/{document=**} {
        allow read: if isAdmin() || isOwner(username);
        allow write: if isAdmin() || isOwner(username);
      }
    }

    match /userStats {
      allow read: if isAdmin();
      match /{username}/{document=**} {
        allow read: if isAdmin() || isOwner(username);
        allow write: if isAdmin() || isOwner(username);
      }
    }

    match /studentActivity {
      allow read: if isAdmin();
      match /{username} {
        allow read: if isAdmin() || isOwner(username);
        allow write: if isAdmin() || isOwner(username);
      }
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
